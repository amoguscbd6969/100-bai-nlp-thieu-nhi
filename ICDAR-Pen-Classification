    "import cv2\n",
    "import numpy as np\n",
    "from PIL import Image\n",
    "\n",
    "class EdgeEnhance:\n",
    "\n",
    "    def __call__(self, img):\n",
    "\n",
    "        img = np.array(img)\n",
    "\n",
    "        blurred = cv2.GaussianBlur(img, (0,0), 1.0)\n",
    "\n",
    "        enhanced = cv2.addWeighted(img, 1.5, blurred, -0.5, 0)\n",
    "\n",
    "        return Image.fromarray(enhanced)"
   ]
