    "import torch.nn as nn\n",
    "from torchvision.models import resnext50_32x4d, convnext_small\n",
    "\n",
    "def build_model(model_name=\"resnext\"):\n",
    "\n",
    "    if model_name == \"resnext\":\n",
    "\n",
    "        model = resnext50_32x4d(weights=\"IMAGENET1K_V1\")\n",
    "        model.fc = nn.Linear(model.fc.in_features, 8)\n",
    "\n",
    "    elif model_name == \"convnext\":\n",
    "\n",
    "        model = convnext_small(weights=\"IMAGENET1K_V1\")\n",
    "        model.classifier[2] = nn.Linear(model.classifier[2].in_features, 8)\n",
    "\n",
    "    return model"
   ]
