    "import torch\n",
    "import torch.nn.functional as F\n",
    "from tqdm.auto import tqdm\n",
    "\n",
    "scaler = torch.cuda.amp.GradScaler()\n",
    "\n",
    "def train_epoch(model, loader, optimizer, device, accum_steps=1, mix_alpha=1.0, cutmix_prob=0.3):\n",
    "    model.train()\n",
    "    total_loss = 0\n",
    "\n",
    "    optimizer.zero_grad(set_to_none=True)\n",
    "\n",
    "    for step, (images, labels) in enumerate(tqdm(loader)):\n",
    "        images = images.to(device, memory_format=torch.channels_last)\n",
    "        labels = labels.to(device)\n",
    "\n",
    "        # 🔥 Apply MixUp / CutMix\n",
    "        images, targets_a, targets_b, lam = mixup_cutmix(\n",
    "            images, labels,\n",
    "            alpha=mix_alpha,\n",
    "            cutmix_prob=cutmix_prob\n",
    "        )\n",
    "\n",
    "        with torch.cuda.amp.autocast():\n",
    "            logits = model(images)\n",
    "\n",
    "            loss = (\n",
    "                lam * F.cross_entropy(logits, targets_a, label_smoothing=0.05)\n",
    "                + (1 - lam) * F.cross_entropy(logits, targets_b, label_smoothing=0.05)\n",
    "            )\n",
    "\n",
    "        loss = loss / accum_steps\n",
    "        scaler.scale(loss).backward()\n",
    "\n",
    "        if (step + 1) % accum_steps == 0:\n",
    "            scaler.step(optimizer)\n",
    "            scaler.update()\n",
    "            optimizer.zero_grad(set_to_none=True)\n",
    "\n",
    "        total_loss += loss.item() * accum_steps\n",
    "\n",
    "    return total_loss / len(loader)"
   ]
  },
